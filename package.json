{
  "name": "@nljerry/wesender-cli",
  "version": "0.1.0",
  "description": "WeSender CLI: e-mails versturen vanuit de terminal",
  "type": "module",
  "bin": {
    "wesender": "./dist/index.js"
  },
  "scripts": {
    "dev":   "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --minify",
    "test":  "bun test"
  },
  "dependencies": {
    "commander":  "^12.0.0",
    "chalk":      "^5.3.0",
    "ora":        "^8.0.1",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript":  "^5.6.0"
  },
  "files": ["dist/"],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nljerry/wesender.git",
    "directory": "apps/cli"
  },
  "homepage": "https://wesender.nl/functies/cli",
  "bugs": "https://github.com/nljerry/wesender/issues",
  "engines": { "node": ">=18" }
}
